# ── ZUNO Frontend Environment Configuration Template ──

# The base URL of the backend API.
# Next.js will fall back to http://localhost:5000 if this is not defined.
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# API Mode: Set to "memory-mock" to run the app in client-side mockup mode using mock data,
# or leave empty/remove to connect to the actual PostgreSQL backend.
NEXT_PUBLIC_API_MODE=

# Receipt Scanning API Simulation configurations:
# - Set NEXT_PUBLIC_RECEIPT_SCAN_MOCK to "true" to simulate scanning instead of hitting the real backend service.
# - NEXT_PUBLIC_RECEIPT_SCAN_MOCK_PROFILE: 'a' (default) or 'b' (overspending test profile).
# - NEXT_PUBLIC_RECEIPT_SCAN_MOCK_DELAY_MS: Simulation delay in milliseconds (defaults to 900).
NEXT_PUBLIC_RECEIPT_SCAN_MOCK=false
NEXT_PUBLIC_RECEIPT_SCAN_MOCK_PROFILE=a
NEXT_PUBLIC_RECEIPT_SCAN_MOCK_DELAY_MS=900

# Custom scan API endpoint if not using mock scanning (defaults to /api/receipt/scan relative to API URL).
NEXT_PUBLIC_RECEIPT_SCAN_ENDPOINT=
