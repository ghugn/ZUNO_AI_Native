PORT=5000
DATABASE_URL=postgresql://your_postgres_username:your_postgres_password@localhost:5432/your_database_name
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Cloud Cron ──────────────────────────────────────────────
# Để trống (không set) → dùng scheduler nội bộ (dev mode)
# Set giá trị → tắt scheduler nội bộ, yêu cầu Cloud Cron gọi:
#   POST /api/cron/daily-drip    (hàng ngày 00:00)
#   POST /api/cron/monthly-rollover (cuối tháng)
# Header: X-Cron-Secret: <giá trị bên dưới>
# CRON_SECRET=your-strong-random-secret-here

# ── Gemini API Key ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
